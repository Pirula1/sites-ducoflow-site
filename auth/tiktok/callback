const CONFIG = {
  REDIRECT_URI: 'https://ducoflow.duco.nexus/auth/tiktok/callback',
  HOME_URL: 'https://ducoflow.duco.nexus',
  START_URL: 'https://ducoflow.duco.nexus/auth/tiktok/start',
  TIKTOK_TOKEN_URL: 'https://open.tiktokapis.com/v2/oauth/token/',
  TIKTOK_USERINFO_URL: 'https://open.tiktokapis.com/v2/user/info/',
};

export default {
  async fetch(request, env) {
    const url = new URL(request.url);
    if (url.pathname === '/auth/tiktok/callback') return handleCallback(request, env);
    if (url.pathname === '/health') return new Response(JSON.stringify({status:'ok'}), {headers:{'Content-Type':'application/json'}});
    return new Response('Not Found', {status:404});
  },
};

async function handleCallback(request, env) {
  const url = new URL(request.url);
  const code = url.searchParams.get('code');
  const state = url.searchParams.get('state');
  const error = url.searchParams.get('error');
  const errorDescription = url.searchParams.get('error_description');

  if (error) return renderError(error, errorDescription || 'Erro desconhecido');
  if (!code) return renderError('missing_code', 'Nenhum authorization code recebido');

  try {
    const tokenData = await exchangeCodeForToken(code, env);
    if (!tokenData.access_token) throw new Error('Falha ao obter access_token');
    const userInfo = await fetchUserInfo(tokenData.access_token, env);
    return renderSuccess(userInfo, tokenData, state);
  } catch (err) {
    return renderError('processing_error', err.message);
  }
}

async function exchangeCodeForToken(code, env) {
  const clientKey = env.TIKTOK_CLIENT_KEY || 'sbawxmdxdswpfpnjaa';
  const clientSecret = env.TIKTOK_CLIENT_SECRET;
  if (!clientSecret) throw new Error('TIKTOK_CLIENT_SECRET não configurado! Adicione em Settings > Variables');

  const res = await fetch(CONFIG.TIKTOK_TOKEN_URL, {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: new URLSearchParams({client_key: clientKey, client_secret: clientSecret, code, grant_type: 'authorization_code', redirect_uri: CONFIG.REDIRECT_URI}),
  });
  const data = await res.json();
  if (!res.ok || data.error) throw new Error(JSON.stringify(data));
  return data.data || data;
}

async function fetchUserInfo(accessToken) {
  const url = new URL(CONFIG.TIKTOK_USERINFO_URL);
  url.searchParams.set('fields', 'open_id,union_id,avatar_url,display_name,bio_description,follower_count,following_count,likes_count,video_count');
  const res = await fetch(url, {headers: {'Authorization': `Bearer ${accessToken}`, 'Content-Type': 'application/json'}});
  const data = await res.json();
  if (!res.ok || data.error) throw new Error(JSON.stringify(data));
  return data.data || data;
}

function formatNumber(n){return n>=1e6?(n/1e6).toFixed(1)+'M':n>=1e3?(n/1e3).toFixed(1)+'K':n.toString();}

